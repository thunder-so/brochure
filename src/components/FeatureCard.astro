---
interface Props {
  title: string;
  icon: string;
  description: string;
}

const { title, icon, description } = Astro.props;
---

<div class="bg-secondary border border-border rounded-3xl p-8 hover:border-primary/30 transition-all group">
  <div class="text-4xl mb-6 transition-transform group-hover:scale-110 inline-block">
    {icon}
  </div>
  <h3 class="text-2xl font-semibold mb-4 text-foreground">{title}</h3>
  <p class="text-muted-foreground leading-relaxed">
    {description}
  </p>
</div>
