---
---
<site-search>
  <button data-open-modal disabled aria-label="Search" aria-keyshortcuts="Control+K">
    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
    <span>Search</span>
    <kbd><kbd id="search-meta-key">Ctrl</kbd><kbd>K</kbd></kbd>
  </button>
  <script is:inline>
    if (/(Mac|iPhone|iPod|iPad)/i.test(navigator.platform)) {
      const k = document.getElementById('search-meta-key');
      if (k) k.textContent = '⌘';
    }
  </script>

  <dialog aria-label="Search">
    <div class="dialog-frame">
      <button data-close-modal>Cancel</button>
      <div id="starlight__search"></div>
    </div>
  </dialog>
</site-search>

<script>
  import '@pagefind/default-ui/css/ui.css';

  class SiteSearch extends HTMLElement {
    constructor() {
      super();
      const openBtn = this.querySelector<HTMLButtonElement>('button[data-open-modal]')!;
      const closeBtn = this.querySelector<HTMLButtonElement>('button[data-close-modal]')!;
      const dialog = this.querySelector('dialog')!;
      const dialogFrame = this.querySelector('.dialog-frame')!;

      const onClick = (e: MouseEvent) => {
        const isLink = 'href' in (e.target || {});
        if (isLink || (document.body.contains(e.target as Node) && !dialogFrame.contains(e.target as Node))) {
          closeModal();
        }
      };

      const openModal = (e?: MouseEvent) => {
        dialog.showModal();
        document.body.toggleAttribute('data-search-modal-open', true);
        this.querySelector('input')?.focus();
        e?.stopPropagation();
        window.addEventListener('click', onClick);
      };

      const closeModal = () => {
        dialog.close();
        document.body.toggleAttribute('data-search-modal-open', false);
        window.removeEventListener('click', onClick);
      };

      openBtn.addEventListener('click', openModal);
      openBtn.disabled = false;
      closeBtn.addEventListener('click', closeModal);

      window.addEventListener('keydown', (e) => {
        if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
          dialog.open ? closeModal() : openModal();
          e.preventDefault();
        }
        if (e.key === 'Escape') closeModal();
      });

      const onIdle = window.requestIdleCallback || ((cb: () => void) => setTimeout(cb, 1));
      onIdle(async () => {
        const { PagefindUI } = await import('@pagefind/default-ui');
        new PagefindUI({
          element: '#starlight__search',
          baseUrl: '/',
          bundlePath: '/pagefind/',
          showImages: false,
          showSubResults: true,
        });
      });
    }
  }

  customElements.define('site-search', SiteSearch);
</script>

<style is:global>
  site-search { display: contents; }

  button[data-open-modal] {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    border: 1px solid hsl(var(--border));
    border-radius: 0.5rem;
    padding: 0.375rem 0.75rem;
    background: hsl(var(--background));
    color: hsl(var(--muted-foreground));
    font-size: 0.875rem;
    cursor: pointer;
    width: 200px;
    transition: border-color 0.15s, color 0.15s;
  }
  button[data-open-modal]:hover {
    border-color: hsl(var(--foreground) / 0.4);
    color: hsl(var(--foreground));
  }
  button[data-open-modal] kbd {
    margin-inline-start: auto;
    display: flex;
    gap: 0.2em;
    font-size: 0.7rem;
    opacity: 0.6;
  }
  button[data-open-modal] kbd kbd {
    border: 1px solid hsl(var(--border));
    border-radius: 0.25rem;
    padding: 0.1em 0.35em;
  }

  dialog {
    margin: 0;
    padding: 0;
    background: hsl(var(--background));
    border: 1px solid hsl(var(--border));
    width: 100%;
    max-width: 100%;
    height: 100%;
    max-height: 100%;
    box-shadow: 0 25px 50px -12px rgb(0 0 0 / 0.5);
  }
  dialog[open] { display: flex; }
  dialog::backdrop {
    background: hsl(var(--background) / 0.7);
    backdrop-filter: blur(4px);
  }
  @media (min-width: 50rem) {
    dialog {
      margin: 4rem auto auto;
      border-radius: 0.5rem;
      width: 90%;
      max-width: 40rem;
      height: max-content;
      min-height: 15rem;
      max-height: calc(100% - 8rem);
    }
  }

  .dialog-frame {
    display: flex;
    flex-direction: column;
    flex-grow: 1;
    gap: 1rem;
    padding: 1.5rem;
    overflow: auto;
    position: relative;
  }

  button[data-close-modal] {
    position: absolute;
    top: 1rem;
    right: 1rem;
    border: 0;
    background: transparent;
    color: hsl(var(--muted-foreground));
    cursor: pointer;
    font-size: 0.875rem;
  }

  [data-search-modal-open] { overflow: hidden; }

  #starlight__search {
    --pagefind-ui-scale: 1;
    --pagefind-ui-primary: hsl(var(--primary));
    --pagefind-ui-text: hsl(var(--foreground));
    --pagefind-ui-background: hsl(var(--background));
    --pagefind-ui-border: hsl(var(--border));
    --pagefind-ui-border-radius: 0.375rem;
    --pagefind-ui-font: inherit;
  }
</style>
