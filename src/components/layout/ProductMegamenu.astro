---
import { Box, Layout, Zap, Package } from "lucide-astro";
import { Icon } from 'astro-icon/components';

interface Framework {
  name: string;
  icon?: any;
  logo?: string;
  href: string;
}

interface Pattern {
  name: string;
  icon: any;
  href: string;
}

export interface Props {
  isMobile?: boolean;
}

const { isMobile = false } = Astro.props;

const frameworks = [
  {
    name: "Next.js",
    icon: "tabler:brand-nextjs",
    description: "Full-stack React framework",
    href: '/docs/frameworks/nextjs',
  },
  {
    name: "Nuxt",
    icon: "vscode-icons:file-type-nuxt",
    description: "Vue.js framework",
    href: '/docs/frameworks/nuxt',
  },
  {
    name: "Astro",
    icon: "vscode-icons:file-type-astro",
    description: "Content-focused framework",
    href: '/docs/frameworks/astro',
  },
  {
    name: "TanStack Start",
    logo: "/frameworks/TanStack.svg",
    description: "Full-stack React framework",
    href: '/docs/frameworks/tanstack',
  },
  {
    name: "Vite",
    icon: "vscode-icons:file-type-vite",
    description: "Next-gen frontend tooling",
    href: '/docs/frameworks/vite',
  },
  {
    name: "NestJS",
    icon: "vscode-icons:file-type-nestjs",
    description: "Node.js framework",
    href: '/docs/frameworks/nestjs',
  },
];

const comparisons = [
  {
    name: "vs AWS Amplify",
    icon: 'logos:aws-amplify',
    href: "/alternatives/aws-amplify",
    description: "Thunder vs Amplify",
  },
  {
    name: "vs SST",
    icon: 'logos:sst-icon',
    href: "/alternatives/sst",
    description: "Thunder vs SST",
  },
];

const patterns = [
  { 
    name: "Static", 
    icon: 'tabler:file', 
    href: "/docs/patterns/static", 
    description: "S3 + CloudFront" 
  },
  { 
    name: "Lambda", 
    icon: 'tabler:lambda', 
    href: "/docs/patterns/lambda", 
    description: "Lambda + API Gateway" 
  },
  { 
    name: "Fargate", 
    icon: 'tabler:server', 
    href: "/docs/patterns/fargate", 
    description: "Fargate + ALB" 
  },
  { 
    name: "Serverless", 
    icon: 'tabler:cloud-bolt', 
    href: "/docs/patterns/serverless", 
    description: "Lambda + S3 + CloudFront" 
  },
];
---

{isMobile ? (
  <>
    {/* Mobile Menu Content */}
    <div class="space-y-4">
      {/* Platform Overview */}
      <a href="/platform" class="flex items-start gap-3 rounded p-3 hover:bg-secondary transition-colors">
        <div class="flex-shrink-0 mt-1">
          <Box class="h-5 w-5 text-primary" />
        </div>
        <div>
          <div class="font-medium text-foreground">Platform Overview</div>
          <div class="text-xs text-muted-foreground">Learn what Thunder can do</div>
        </div>
      </a>

      {/* Frameworks Section */}
      <div>
        <div class="text-xs font-semibold text-muted-foreground uppercase tracking-wider mb-2">Frameworks</div>
        <ul class="space-y-2 ml-2">
          {frameworks.map((framework) => (
            <li>
              <a href={framework.href} class="text-sm text-foreground hover:text-primary transition-colors">
                {framework.name}
              </a>
            </li>
          ))}
        </ul>
      </div>

      {/* Patterns Section */}
      <div>
        <div class="text-xs font-semibold text-muted-foreground uppercase tracking-wider mb-2">Patterns</div>
        <ul class="space-y-2 ml-2">
          {patterns.map((pattern) => (
            <li>
              <a href={pattern.href} class="text-sm text-foreground hover:text-primary transition-colors">
                {pattern.name}
              </a>
            </li>
          ))}
        </ul>
      </div>
      {/* Comparisons Section */}
      <div>
        <div class="text-xs font-semibold text-muted-foreground uppercase tracking-wider mb-2">Comparisons</div>
        <ul class="space-y-2 ml-2">
          {comparisons.map((item) => (
            <li>
              <a href={item.href} class="text-sm text-foreground hover:text-primary transition-colors">
                {item.name}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </>
) : (
  <>
    {/* Desktop Megamenu */}
    <div class="absolute top-full left-0 mt-1 w-[62rem] rounded border border-border bg-popover shadow-xl opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200">
      <div class="grid grid-cols-4 gap-6 p-6">
        {/* Column 1: Platform Overview */}
        <a href="/platform" class="col-span-1 flex flex-col items-start rounded border border-border/50 bg-secondary/30 p-4 hover:bg-secondary/50 transition-colors">
          <div class="mb-3 flex items-center justify-center w-12 h-12 rounded bg-primary/10">
            <Box class="h-6 w-6 text-primary" />
          </div>
          <h3 class="font-semibold text-foreground mb-1">Platform Overview</h3>
          <p class="text-xs text-muted-foreground">Learn what Thunder can do</p>
        </a>

        {/* Column 2: Frameworks */}
        <div class="col-span-1">
          <h3 class="font-semibold text-sm text-foreground mb-3">Frameworks</h3>
          <ul class="space-y-2">
            {frameworks.map((framework) => (
              <li>
                <a href={framework.href} class="flex items-center gap-3 rounded px-3 py-2 text-sm text-foreground hover:bg-secondary transition-colors">
                  <span class="text-lg">
                    {framework.icon
                      ? <Icon name={framework.icon} class="w-5 h-5 opacity-70" />
                      : <img src={framework.logo} alt={framework.name} class="w-5 h-5 object-contain filter brightness-0 invert opacity-70 group-hover:opacity-100 transition-opacity" />
                    }
                  </span>
                  <span>{framework.name}</span>
                </a>
              </li>
            ))}
          </ul>
        </div>

        {/* Column 3: Patterns */}
        <div class="col-span-1">
          <h3 class="font-semibold text-sm text-foreground mb-3">Patterns</h3>
          <ul class="space-y-2">
            {patterns.map((pattern) => {
              return (
                <li>
                  <a href={pattern.href} class="flex items-center gap-3 rounded px-3 py-2 hover:bg-secondary transition-colors">
                    <Icon name={pattern.icon} class="text-primary" />
                    <div>
                      <div class="text-sm font-medium text-foreground">{pattern.name}</div>
                      <div class="text-xs pt-1 font-mono text-muted-foreground">{pattern.description}</div>
                    </div>
                  </a>
                </li>
              );
            })}
          </ul>
        </div>

        {/* Column 4: Comparisons */}
        <div class="col-span-1">
          <h3 class="font-semibold text-sm text-foreground mb-3">Comparisons</h3>
          <ul class="space-y-2">
            {comparisons.map((item) => (
              <li>
                <a href={item.href} class="flex items-center gap-3 rounded px-3 py-2 hover:bg-secondary transition-colors">
                  <Icon name={item.icon} class="text-primary" />
                  <div>
                    <div class="text-sm font-medium text-foreground">{item.name}</div>
                    <div class="text-xs pt-1 font-mono text-muted-foreground">{item.description}</div>
                  </div>
                </a>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </>
)}

