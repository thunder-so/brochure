---
import { Icon } from "astro-icon/components";

const footerLinks = {
  product: [
    { name: "Patterns", href: "/docs/patterns" },
    { name: "Console", href: "/platform" },
    { name: "Frameworks", href: "/docs/frameworks" },
  ],
  alternatives: [
    { name: 'vs AWS Amplify', href: '/alternatives/aws-amplify' },
    { name: 'vs SST', href: '/alternatives/sst' },
  ],
  company: [
    { name: "About", href: "https://www.linkedin.com/company/cloudbits" },
    { name: "Blog", href: "/blog" },
    { name: "Open Source", href: "https://github.com/thunder-so", external: true },
  ],
  resources: [
    { name: "Documentation", href: "/docs" },
    { name: "Support", href: "/docs/support" },
  ],
  legal: [
    { name: "Terms of Service", href: "/legal/terms" },
    { name: "Privacy Policy", href: "/legal/privacy" },
  ],
};
---

<footer class="border-t border-border bg-card">
  <div class="container mx-auto py-16">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {/* Brand — 1/3 */}
      <div class="pl-6">
        <a href="/" class="flex items-center gap-2 mb-6">
          <img src="/images/thunder.svg" alt="Thunder" class="h-6 w-6 rounded" />
          <span class="text-md font-bold text-foreground">Thunder</span>
        </a>
        <p class="text-sm text-muted-foreground mt-2 mb-2">
          The precision deployment platform
        </p>
        <p class="text-sm text-muted-foreground mb-6">
            &copy; 2026 CloudBits, Inc.
          </p>
        <div class="flex gap-4">
          <a href="https://github.com/thunder-so" target="_blank" rel="noopener noreferrer" class="text-muted-foreground hover:text-foreground transition-colors">
            <Icon name="tabler:brand-github" class="h-5 w-5" />
          </a>
          <a href="https://x.com/thunderdotso" target="_blank" rel="noopener noreferrer" class="text-muted-foreground hover:text-foreground transition-colors">
            <Icon name="tabler:brand-x" class="h-5 w-5" />
          </a>
          <a href="https://discord.gg/uNbrp6QYZ6" target="_blank" rel="noopener noreferrer" class="text-muted-foreground hover:text-foreground transition-colors">
            <Icon name="tabler:brand-discord" class="h-5 w-5" />
          </a>
        </div>
      </div>

      {/* Links — 2/3 as 2x2 grid */}
      <div class="md:col-span-2 grid grid-cols-2 gap-8">
        <div>
          <h4 class="font-semibold text-foreground mb-4">Product</h4>
          <ul class="space-y-3">
            {footerLinks.product.map((link) => (
              <li>
                <a href={link.href} class="text-sm text-muted-foreground hover:text-foreground transition-colors">
                  {link.name}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <div>
          <h4 class="font-semibold text-foreground mb-4">Company</h4>
          <ul class="space-y-3">
            {footerLinks.company.map((link) => (
              <li>
                <a
                  href={link.href}
                  target={link.external ? "_blank" : undefined}
                  rel={link.external ? "noopener noreferrer" : undefined}
                  class="text-sm text-muted-foreground hover:text-foreground transition-colors"
                >
                  {link.name}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <div>
          <h4 class="font-semibold text-foreground mb-4">Resources</h4>
          <ul class="space-y-3">
            {footerLinks.resources.map((link) => (
              <li>
                <a href={link.href} class="text-sm text-muted-foreground hover:text-foreground transition-colors">
                  {link.name}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <div>
          <h4 class="font-semibold text-foreground mb-4">Legal</h4>
          <ul class="space-y-3">
            {footerLinks.legal.map((link) => (
              <li>
                <a href={link.href} class="text-sm text-muted-foreground hover:text-foreground transition-colors">
                  {link.name}
                </a>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </div>
</footer>