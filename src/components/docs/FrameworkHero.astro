---
import { Icon } from 'astro-icon/components';
import frameworksData from '@/data/frameworks.json';

interface Props {
  name: string;
  title?: string;
}

const { name, title } = Astro.props;
const framework = frameworksData.frameworks.find(f => f.name === name);
if (!framework) throw new Error(`Framework "${name}" not found in frameworks.json`);
---

<div class="not-content framework-hero flex items-top gap-6 mb-8 pb-4 border-b border-border">
  <div class="shrink-0 w-16 h-16 flex items-center justify-center rounded-xl border border-[var(--sl-color-gray-5)] bg-[var(--sl-color-black)] p-3">
    {framework.icon
      ? <Icon name={framework.icon} class="w-full h-full" />
      : framework.logo
        ? <img src={framework.logo} alt={framework.name} class="w-full h-full object-contain" />
        : null
    }
  </div>
  <div>
    <h1 style="font-size: 1.5rem; font-weight: 700; margin: 0 0 0.25rem 0;">{title ?? framework.name}</h1>
    <p class="text-sm text-[var(--sl-color-gray-2)] !mt-1.5 !mb-1">{framework.description}</p>
    <a
      href={framework.site}
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center gap-1 text-xs text-[var(--sl-color-text-accent)] hover:underline"
    >
      {framework.site?.replace('https://', '')}
      <Icon name="tabler:external-link" class="w-3 h-3" />
    </a>
  </div>
</div>
