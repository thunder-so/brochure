---
import { Icon } from 'astro-icon/components';
import patternsData from '@/data/frameworks.json';

interface Props {
  patterns: string[];
}

const { patterns } = Astro.props;
const { patterns: patternConfig } = patternsData;
---

<div class="flex gap-1.5 mt-2">
  {patterns.map((patternKey) => {
    const config = patternConfig[patternKey as keyof typeof patternConfig];
    if (!config) return null;
    return (
      <span
        class={`inline-flex items-center justify-center w-6 h-6 cursor-pointer transition-all duration-200 hover:scale-110`}
        title={config.label}
      >
        <Icon name={config.icon} class={`w-3.5 h-3.5 ${config.color}`} />
      </span>
    );
  })}
</div>
