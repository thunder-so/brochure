---
import { Terminal, ArrowRight, Github } from "lucide-astro";
import Button from "../Button.astro";
---

<section class="relative flex items-center justify-center overflow-hidden">
  {/* Background Effects */}
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,hsl(var(--thunder-yellow)/0.08)_0%,transparent_50%)]" />
  <!-- <div class="absolute top-1/4 left-1/2 -translate-x-1/2 w-[800px] h-[400px] bg-[radial-gradient(ellipse_at_center,hsl(var(--thunder-yellow)/0.1)_0%,transparent_70%)] blur-3xl" /> -->
  <!-- <div class="absolute inset-0 bg-[linear-gradient(hsl(var(--border)/0.3)_1px,transparent_1px),linear-gradient(90deg,hsl(var(--border)/0.3)_1px,transparent_1px)] bg-[size:64px_64px] [mask-image:radial-gradient(ellipse_at_center,black_30%,transparent_70%)]" /> -->

  <div class="container relative mx-auto px-4 pt-32 pb-24">
    <div class="max-w-3xl mx-auto text-center space-y-8">

      {/* Badge */}
      <div class="inline-flex items-center gap-2 rounded-full border border-border bg-secondary/50 px-4 py-1.5 text-sm text-muted-foreground animate-fade-in">
        <Terminal class="h-4 w-4 text-primary" />
        <span>Announcing fullstack serverless architecture</span>
      </div>

      {/* Headline */}
      <h1 class="text-3xl md:text-3xl font-extrabold tracking-tight text-foreground leading-[1.1] animate-fade-in-up">
        Localhost to <span class="text-primary">production</span> in minutes
      </h1>

      {/* Subheadline */}
      <p class="text-md text-muted-foreground max-w-xl mx-auto leading-relaxed animate-fade-in-up" style="animation-delay: 0.1s">
        Thunder transforms your application code into production-ready AWS resources. Just ship.
      </p>

      {/* CLI Quickstart */}
      <div class="max-w-md mx-auto animate-fade-in-up" style="animation-delay: 0.15s">
        <div class="bg-secondary/80 rounded-xl pt-2 px-4 py-4 border border-border text-left">
          <div class="flex items-center justify-between mb-3">
            <div class="flex gap-1.5">
              <div class="w-2.5 h-2.5 rounded-full bg-muted"></div>
              <div class="w-2.5 h-2.5 rounded-full bg-muted"></div>
              <div class="w-2.5 h-2.5 rounded-full bg-muted"></div>
            </div>
            <span class="text-[10px] font-mono text-muted-foreground tracking-widest uppercase">Quickstart</span>
          </div>
          <div class="flex items-center justify-between">
            <code class="font-mono text-sm text-foreground/80">
              <span class="text-primary">bun</span> add @thunder-so/thunder --development
            </code>
            <button id="copy-btn" aria-label="Copy to clipboard" class="text-muted-foreground hover:text-foreground transition-colors ml-3 shrink-0">
              <svg id="icon-copy" xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
                <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
              </svg>
              <svg id="icon-check" xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 hidden text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
            </button>
          </div>
        </div>
      </div>

<script>
  const btn = document.getElementById('copy-btn');
  const iconCopy = document.getElementById('icon-copy');
  const iconCheck = document.getElementById('icon-check');
  btn?.addEventListener('click', () => {
    navigator.clipboard.writeText('bun add @thunder-so/thunder --development');
    iconCopy?.classList.add('hidden');
    iconCheck?.classList.remove('hidden');
    setTimeout(() => {
      iconCopy?.classList.remove('hidden');
      iconCheck?.classList.add('hidden');
    }, 2000);
  });
</script>

      {/* CTAs */}
      <div class="flex flex-col sm:flex-row gap-4 justify-center items-center animate-fade-in-up" style="animation-delay: 0.2s">
        <Button variant="hero" size="md" href="/api/login">
          Start Orchestrating
          <ArrowRight class="h-5 w-5 ml-2" />
        </Button>
        <Button variant="hero-outline" size="md" href="/docs">
          Read Docs
        </Button>
      </div>

    </div>
  </div>

  {/* Scroll Indicator 
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
    <div class="w-6 h-10 rounded-full border-2 border-border flex items-start justify-center p-2">
      <div class="w-1.5 h-2.5 rounded-full bg-primary animate-pulse" />
    </div>
  </div>*/}
</section>
