---
import { ArrowRight } from "lucide-astro";
import { Icon } from "astro-icon/components";
import Button from "../Button.astro";

const frameworks = [
  { name: "Next.js",        icon: "tabler:brand-nextjs",        description: "Full-stack React framework",   href: '/docs/frameworks/nextjs' },
  { name: "Nuxt",           icon: "vscode-icons:file-type-nuxt",           description: "Vue.js meta-framework",             href: '/docs/frameworks/nuxt' },
  { name: "Astro",          icon: "vscode-icons:file-type-astro",          description: "Content-focused framework",    href: '/docs/frameworks/astro' },
  { name: "TanStack Start", icon: null, logo: "https://tanstack.com/images/logos/logo-color-100.png", description: "Full-stack React framework",   href: '/docs/frameworks/tanstack' },
  { name: "Vite",           icon: "vscode-icons:file-type-vite",         description: "Next-gen frontend tooling",    href: '/docs/frameworks/vite' },
  { name: "NestJS",         icon: "vscode-icons:file-type-nestjs",         description: "Node.js framework",            href: '/docs/frameworks/nestjs' },
];
---

<section class="relative">
  <div class="container mx-auto py-24">
    <div class="text-center mb-8">
      <h2 class="text-2xl font-bold text-foreground mb-4">
        Deploy any framework
      </h2>
      <p class="text-md text-muted-foreground max-w-2xl mx-auto">
        Automatic detection and optimized configurations for your favorite frameworks.
      </p>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-6 mb-8">
      {frameworks.map((framework) => (
        <a
          href={framework.href}
          class="group relative rounded border border-border bg-card p-6 hover:border-primary/50 transition-all duration-300 flex flex-col items-center text-center hover:bg-card/80"
        >
          <div class="w-12 h-12 mb-4 flex items-center justify-center">
            {framework.icon
              ? <Icon name={framework.icon} class="w-10 h-10 opacity-70 group-hover:opacity-100 transition-opacity" />
              : framework.logo
                ? <img src={framework.logo} alt={framework.name} class="w-10 h-10 opacity-70 group-hover:opacity-100 transition-opacity object-contain" />
                : <span class="text-2xl font-black text-muted-foreground group-hover:text-foreground transition-colors">TS</span>
            }
          </div>
          <h3 class="font-semibold text-foreground mb-1">{framework.name}</h3>
          <p class="text-xs text-muted-foreground">{framework.description}</p>
        </a>
      ))}
    </div>

    <div class="text-center">
      <Button variant="outline" size="lg" href="/docs/frameworks">
        View all frameworks
        <ArrowRight class="h-4 w-4 ml-2" />
      </Button>
    </div>
  </div>
</section>
