---
import { Icon } from 'astro-icon/components';
---

<section class="bg-card/50">
  <div class="container mx-auto px-12 py-24">
    <div class="text-center mb-16">
      <h2 class="text-xl font-bold text-foreground mb-4">Click, click, click, done</h2>
      <p class="text-md text-muted-foreground max-w-2xl mx-auto">
        Connect your accounts, configure your app, and deploy automatically.
      </p>
    </div>

    <div id="steps-tabs">
      {/* Tab bar */}
      <div role="tablist" class="flex justify-center border-b border-border">
        {[
          { id: 'aws',       label: '1. Connect AWS' },
          { id: 'github',    label: '2. Connect GitHub' },
          { id: 'configure', label: '3. Configure' },
          { id: 'deploy',    label: '4. Deploy' },
        ].map(t => (
          <a
            role="tab"
            href={`#${t.id}`}
            id={`tab-${t.id}`}
            aria-controls={`panel-${t.id}`}
            class="steps-tab px-5 py-3 text-sm font-medium text-muted-foreground border-b-2 border-transparent -mb-px hover:text-foreground transition-colors"
          >{t.label}</a>
        ))}
      </div>

      {/* Panels */}
      <div id="panel-aws" role="tabpanel" aria-labelledby="tab-aws" class="steps-panel hidden">
        <div class="flex justify-between gap-12 px-8 py-12">
          <div>
            <div class="inline-flex items-center justify-center w-14 h-14 rounded-2xl bg-orange-400/10 text-orange-400 mb-6">
              <Icon name="tabler:brand-aws" class="w-8 h-8" />
            </div>
            <h3 class="text-2xl font-bold text-foreground mb-4">Connect to AWS</h3>
            <p class="text-muted-foreground mb-6">Link your AWS account to provision infrastructure and deploy your applications.</p>
            <div class="text-muted-foreground flex gap-2"><Icon name="tabler:arrow-narrow-right" class="h-6 w-4" /><a href="/docs/aws#iam" class="hover:text-primary hover:underline">Create an IAM role with the required permissions</a></div>
            <div class="text-muted-foreground flex gap-2 mt-2"><Icon name="tabler:arrow-narrow-right" class="h-6 w-4" /><a href="/docs/aws#cloudformation" class="hover:text-primary hover:underline">Connect using CloudFormation</a></div>
          </div>
          <div class="w-full max-w-md rounded-2xl border border-border bg-background/80 backdrop-blur-sm shadow-2xl shadow-primary/5 overflow-hidden">
            <div class="px-6 pt-6 pb-3 border-b border-border bg-card">
              <h2 class="text-xl font-semibold text-foreground">Add new AWS account</h2>
              <p class="mt-2 text-sm text-muted-foreground leading-relaxed">Enter the Access Key ID and Secret Access Key for the IAM role you have created.</p>
            </div>
            <div class="p-6 space-y-5 bg-gradient-to-b from-background to-card">
              <div class="space-y-1.5">
                <div class="text-sm font-medium text-foreground">Access Key ID <span class="text-red-500">*</span></div>
                <div class="w-full px-4 py-2.5 bg-muted/30 border border-border rounded-lg h-10 flex items-center text-muted-foreground font-mono tracking-wide">AKIAIOSFODNN7EXAMPLE</div>
              </div>
              <div class="space-y-1.5">
                <div class="text-sm font-medium text-foreground">Secret Access Key <span class="text-red-500">*</span></div>
                <div class="w-full px-4 py-2.5 bg-muted/30 border border-border rounded-lg h-10 flex items-center text-muted-foreground font-mono tracking-widest">••••••••••••••••••••••••••••••••</div>
              </div>
              <a href="#github" class="w-full px-4 py-2.5 bg-primary/10 text-primary rounded-lg border border-primary/20 h-10 flex items-center justify-center font-medium">Connect AWS Account →</a>
            </div>
          </div>
        </div>
      </div>

      <div id="panel-github" role="tabpanel" aria-labelledby="tab-github" class="steps-panel hidden">
        <div class="flex justify-between gap-12 px-8 py-12">
          <div>
            <div class="inline-flex items-center justify-center w-14 h-14 rounded-2xl bg-blue-400/10 text-blue-400 mb-6">
              <Icon name="tabler:brand-github" class="w-8 h-8" />
            </div>
            <h3 class="text-2xl font-bold text-foreground mb-4">Connect to Github</h3>
            <p class="text-muted-foreground mb-6">Connect your GitHub repository to enable automated deployments on every push.</p>
            <div class="text-muted-foreground flex gap-2"><Icon name="tabler:arrow-narrow-right" class="h-6 w-4" /><a href="/docs/github#thunder-github-app" class="hover:text-primary hover:underline">Installing the Thunder Github App</a></div>
            <div class="text-muted-foreground flex gap-2 mt-2"><Icon name="tabler:arrow-narrow-right" class="h-6 w-4" /><a href="/docs/github#permissions" class="hover:text-primary hover:underline">Managing permissions for personal and organization accounts</a></div>
            <div class="text-muted-foreground flex gap-2 mt-2"><Icon name="tabler:arrow-narrow-right" class="h-6 w-4" /><a href="/docs/github#user-access-token" class="hover:text-primary hover:underline">Generating User Access Token for webhook</a></div>
          </div>
          <div class="relative w-full max-w-md space-y-2">
            {[
              { initial: 'M', name: 'cloudbitsio / examples-spa' },
              { initial: 'A', name: 'cloudbitsio / examples-webservice' },
              { initial: 'C', name: 'cloudbitsio / examples-lambda' },
            ].map(repo => (
              <div class="flex items-center justify-between px-5 py-4 rounded-xl bg-muted/20 border border-border hover:bg-muted/30 transition-colors">
                <div class="flex items-center gap-4">
                  <div class="w-10 h-10 rounded-full bg-primary/10 flex items-center justify-center">{repo.initial}</div>
                  <div class="text-sm font-medium text-foreground">{repo.name}</div>
                </div>
                <a href="#configure" class="px-4 py-1.5 text-sm font-medium bg-primary/10 text-primary rounded-lg border border-primary/20">Select →</a>
              </div>
            ))}
          </div>
        </div>
      </div>

      <div id="panel-configure" role="tabpanel" aria-labelledby="tab-configure" class="steps-panel hidden">
        <div class="flex justify-between gap-12 px-8 py-12">
          <div>
            <div class="inline-flex items-center justify-center w-14 h-14 rounded-2xl bg-emerald-400/10 text-emerald-400 mb-6">
              <Icon name="tabler:settings" class="w-8 h-8" />
            </div>
            <h3 class="text-2xl font-bold text-foreground mb-4">Configure application</h3>
            <p class="text-muted-foreground mb-6">Set up your application settings, environment variables, and deployment preferences.</p>
            <div class="text-muted-foreground flex gap-2"><Icon name="tabler:arrow-narrow-right" class="h-6 w-4" /><a href="/docs/patterns/static" class="hover:text-primary hover:underline">Configuring a static site</a></div>
            <div class="text-muted-foreground flex gap-2 mt-2"><Icon name="tabler:arrow-narrow-right" class="h-6 w-4" /><a href="/docs/patterns/lambda" class="hover:text-primary hover:underline">Configuring a Lambda function with Docker container</a></div>
            <div class="text-muted-foreground flex gap-2 mt-2"><Icon name="tabler:arrow-narrow-right" class="h-6 w-4" /><a href="/docs/patterns/fargate" class="hover:text-primary hover:underline">Configuring a Fargate service with Docker</a></div>
            <div class="text-muted-foreground flex gap-2 mt-2"><Icon name="tabler:arrow-narrow-right" class="h-6 w-4" /><a href="/docs/console/environment-variables" class="hover:text-primary hover:underline">Environment Variables and Secrets</a></div>
          </div>
          <div class="relative w-full max-w-md">
            <div class="bg-card rounded-xl overflow-hidden border border-border shadow-2xl shadow-primary/5">
              <div class="p-8 space-y-6">
                {[
                  { label: 'Output Directory', value: 'public/' },
                  { label: 'Runtime', value: 'Node.js 24' },
                  { label: 'Install Command', value: 'bun install' },
                  { label: 'Build Command', value: 'bun run build' },
                ].map(field => (
                  <div class="space-y-2">
                    <label class="text-sm font-medium">{field.label}</label>
                    <div class="h-10 bg-muted/30 rounded-md border border-border px-4 flex items-center text-sm">{field.value}</div>
                  </div>
                ))}
                <a href="#deploy" class="w-full px-4 py-2.5 bg-primary/10 text-primary rounded-lg border border-primary/20 h-10 flex items-center justify-center font-medium">Deploy →</a>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div id="panel-deploy" role="tabpanel" aria-labelledby="tab-deploy" class="steps-panel hidden">
        <div class="flex justify-between gap-12 px-8 py-12">
          <div>
            <div class="inline-flex items-center justify-center w-14 h-14 rounded-2xl bg-purple-400/10 text-purple-400 mb-6">
              <Icon name="tabler:cloud-bolt" class="w-8 h-8" />
            </div>
            <h3 class="text-2xl font-bold text-foreground mb-4">Automated provisioning with GitOps</h3>
            <p class="text-muted-foreground">Thunder zaps your AWS account and Github together so you can deploy automatically on every push with continuous integration and delivery pipelines.</p>
            <p class="text-muted-foreground mt-2">Your app and pipeline will continue to work even if you disconnect from Thunder. That is the open source promise.</p>
          </div>
          <div class="relative w-full max-w-md">
            <div class="bg-card border border-border rounded-xl p-6 mb-4">
              <h2 class="text-xl font-semibold">nextjs-webapp</h2>
              <div class="flex flex-wrap items-center gap-2 text-sm text-muted-foreground mt-1">
                <span>cloudbitsio / examples-spa</span><span>•</span><span>master</span><span>•</span><span>prod / us-east-1</span>
              </div>
              <a href="#" class="text-primary hover:underline text-sm mt-1 block">https://d2kj9zhpxpegl.cloudfront.net</a>
            </div>
            <div class="bg-card border border-border rounded-xl overflow-hidden shadow-2xl shadow-primary/5">
              <div class="px-6 py-5 flex items-center gap-6 hover:bg-muted/30 transition-colors">
                <div class="w-6 h-6 rounded bg-emerald-400/10 text-emerald-400 flex items-center justify-center">
                  <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
                </div>
                <div class="flex-1"><div class="font-medium">Build #1</div><div class="text-xs text-muted-foreground mt-1">just now</div></div>
                <div class="text-sm text-muted-foreground">2m 20s</div>
              </div>
              {[0.6, 0.35].map(opacity => (
                <div class="px-6 py-5 flex items-center gap-6 border-t border-border/50" style={`opacity:${opacity}`}>
                  <div class="w-6 h-6 rounded-full bg-muted/40"></div>
                  <div class="flex-1 h-4 bg-muted/40 rounded"></div>
                  <div class="w-20 h-4 bg-muted/30 rounded"></div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const ids = ['aws', 'github', 'configure', 'deploy'];

  function activate(id: string) {
    if (!ids.includes(id)) id = 'aws';
    ids.forEach(i => {
      const tab = document.getElementById(`tab-${i}`);
      const panel = document.getElementById(`panel-${i}`);
      const active = i === id;
      tab?.setAttribute('aria-selected', String(active));
      tab?.classList.toggle('text-foreground', active);
      tab?.classList.toggle('border-primary', active);
      tab?.classList.toggle('text-muted-foreground', !active);
      tab?.classList.toggle('border-transparent', !active);
      panel?.classList.toggle('hidden', !active);
    });
  }

  function onHash() {
    activate(location.hash.slice(1));
  }

  window.addEventListener('hashchange', onHash);
  onHash();
</script>
