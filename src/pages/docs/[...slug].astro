---
export const prerender = true;

import { getCollection, render } from 'astro:content'
import DocsLayout from '../../layouts/DocsLayout.astro'
import fs from 'fs'
import path from 'path'

export async function getStaticPaths() {
  const docs = await getCollection('docs')
  const paths: any[] = []
  
  docs.forEach((entry) => {
    paths.push({ params: { slug: entry.id }, props: { entry, isMarkdown: false } })
    paths.push({ params: { slug: `${entry.id}.md` }, props: { entry, isMarkdown: true } })
  })
  
  return paths
}

const { entry, isMarkdown } = Astro.props

if (isMarkdown) {
  // Try .mdx first, then .md
  const base = path.join(process.cwd(), 'src/content/docs', entry.id)
  let rawContent = 'Not Found'
  for (const ext of ['.mdx', '.md']) {
    try { rawContent = fs.readFileSync(base + ext, 'utf-8'); break } catch {}
  }

  const canonicalUrl = entry.id === 'index'
    ? 'https://www.thunder.so/docs'
    : `https://www.thunder.so/docs/${entry.id}`

  return new Response(rawContent, {
    headers: {
      'Content-Type': 'text/plain; charset=utf-8',
      'Link': `<${canonicalUrl}>; rel="canonical"`,
    },
  })
}

const { Content, headings } = await render(entry)
---
<DocsLayout headings={headings} {...entry.data}>
  <Content />
</DocsLayout>
