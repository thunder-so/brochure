---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSection from '../components/home/HeroSection.astro';
import ClaudeSkillSection from '../components/home/ClaudeSkillSection.astro';
import FeaturesSection from '../components/home/FeaturesSection.astro';
import PatternsSection from '../components/home/PatternsSection.astro';
import StepsSection from '../components/home/StepsSection.astro';
import ConsoleSection from '../components/home/ConsoleSection.astro';
import FrameworksSection from '../components/home/FrameworksSection.astro';
import OrchestrationSection from '../components/home/OrchestrationSection.astro';
import CTASection from '../components/home/CTASection.astro';

export const prerender = true;
---

<BaseLayout title="" description="Thunder is an open-source platform-as-a-service that deploys your applications directly to your AWS account. Built for modern frameworks and workflows.">
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": "Thunder",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "Web",
    "description": "Thunder is an open-source platform-as-a-service that deploys your applications directly to your AWS account. Built for modern frameworks like Next.js, Astro, and more.",
    "url": "https://thunderso.dev",
    "offers": {
      "@type": "Offer",
      "price": "0",
      "priceCurrency": "USD"
    },
    "license": "https://opensource.org/licenses/Apache-2.0"
  })} />
  <main>
    <HeroSection />
    <ClaudeSkillSection />
    <FrameworksSection />
    <OrchestrationSection />
    <StepsSection />
    <PatternsSection />
    <FeaturesSection />
    <!-- <ConsoleSection /> -->
    <CTASection />
  </main>
</BaseLayout>